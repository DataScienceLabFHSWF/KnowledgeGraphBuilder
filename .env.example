# Weights & Biases (wandb)
WANDB_PROJECT=kg-builder
WANDB_API_KEY=
# KnowledgeGraphBuilder – Environment Variables
# Copy this file to `.env` and fill in secrets for production.

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Fuseki (optional)
FUSEKI_URL=http://localhost:3030
FUSEKI_USER=admin
FUSEKI_PASSWORD=

# Ollama (external)
OLLAMA_BASE_URL=http://localhost:11434

# KGBuilder
KGBUILDER_ENV=development
KGBUILDER_SECRET_KEY=

# Add other secrets/config as needed
