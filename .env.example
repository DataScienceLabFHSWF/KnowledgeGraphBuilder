# KnowledgeGraphBuilder – Environment Variables
# Copy this file to `.env` and adjust for your setup.
#
# STANDALONE: uses container names kgb-neo4j, kgb-qdrant, etc.
# PLATFORM:   uses kgplatform-neo4j, kgplatform-qdrant, etc.
#             (env vars are overridden by KGPlatform's docker-compose.yml)

# ── Infrastructure ─────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
FUSEKI_ADMIN_PASSWORD=admin

# ── Data stores ────────────────────────────────────────────────
QDRANT_COLLECTION=kgbuilder
FUSEKI_DATASET=kgbuilder

# ── Ollama ─────────────────────────────────────────────────────
# Models are pulled automatically on `docker compose up`.
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=qwen3-embedding
# Host port for Ollama (standalone only)
OLLAMA_PORT=11435

# ── API service ────────────────────────────────────────────────
UVICORN_PORT=8001

# Cross-service URLs (leave empty for standalone, set for platform)
GRAPHQA_API_URL=
ONTOLOGY_API_URL=

# ── Weights & Biases (optional) ────────────────────────────────
WANDB_PROJECT=kg-builder
WANDB_API_KEY=

# ── Misc ───────────────────────────────────────────────────────
KGBUILDER_ENV=development
